# ===========================================
# CertaFix Website — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ---- Supabase / Database ----
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ---- Backend (FastAPI) ----
BACKEND_PORT=8000
SECRET_KEY="your-secret-key-change-in-production"
ADMIN_EMAIL="admin@certafix.com"
# Generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your-password'))"
ADMIN_PASSWORD_HASH="$2b$12$..."

# ---- Stripe ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- Frontend URLs ----
WEBSITE_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3011"
BACKEND_URL="http://localhost:8000"

# ---- Next.js (shared by both frontends) ----
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
